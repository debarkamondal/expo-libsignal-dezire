{
  "name": "expo-libsignal-dezire",
  "version": "0.1.2",
  "description": "Expo Native Module for libsignal-dezire",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "bun run build:android && bun run build:ios && bun run build:ios-sim",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "test": "expo-module test",
    "prepare": "expo-module prepare",
    "prepublishOnly": "expo-module prepublishOnly",
    "expo-module": "expo-module",
    "build:android": "bun run ./scripts/cargo-android.ts",
    "build:ios": "bun run ./scripts/cargo-ios.ts --target=ios",
    "build:ios-sim": "bun run ./scripts/cargo-ios.ts --target=ios-sim"
  },
  "keywords": [
    "react-native",
    "expo",
    "libsignal-dezire"
  ],
  "author": "debarkamondal <debarkamondal@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/debarkamondal/expo-libsignal-dezire.git"
  },
  "bugs": {
    "url": "https://github.com/debarkamondal/expo-libsignal-dezire/issues"
  },
  "homepage": "https://github.com/debarkamondal/expo-libsignal-dezire#readme",
  "files": [
    "build",
    "android",
    "ios",
    "expo-module.config.json"
  ],
  "dependencies": {
    "expo-modules-core": "~57.0.6"
  },
  "devDependencies": {
    "@expo/config-plugins": "~57.0.5",
    "@types/react": "~18.3.12",
    "expo-module-scripts": "^56.0.3",
    "typescript": "^5.3.3",
    "bun-types": "^1.2.0"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*"
  }
}